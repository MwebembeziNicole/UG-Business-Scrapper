# ─────────────────────────────────────────────────────────────────────────────
# UG Business Scraper — environment template
#
# Copy this file to `.env` and fill in real values. The `.env` file holds your
# secrets and is NOT committed to version control. Every variable here is
# optional: if you leave it unset, config.py falls back to the same default the
# app used before this refactor, so the application keeps working out of the box.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database engine ──────────────────────────────────────────────────────────
# auto = PostgreSQL when DATABASE_URL / PGDATABASE / PGHOST is set, else SQLite.
# Force a backend with: postgres | sqlite
DB_ENGINE=auto

# ── PostgreSQL connection (only used on the Postgres backend) ────────────────
# Either provide a full URL ...
# DATABASE_URL=postgresql://postgres:password@localhost:5432/uganda_businesses
# ... or the individual parts:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=uganda_businesses
DB_USER=postgres
DB_PASSWORD=

# ── SQLite (only used on the SQLite backend) ─────────────────────────────────
# SQLITE_DB_FILENAME=uganda_businesses.db
# SQLITE_DB_PATH=

# ── Firecrawl API ────────────────────────────────────────────────────────────
# Secret. Required for the platforms that use Firecrawl. Existing installs
# already have this stored in the database settings table.
FIRECRAWL_API_KEY=

# ── Flask / web server ───────────────────────────────────────────────────────
# Session secret. If left blank, the app generates one and stores it in the DB.
FLASK_SECRET_KEY=
HOST=127.0.0.1
PORT=5050

# ── File locations (defaults are project-relative) ───────────────────────────
# EXPORT_DIR=
# DAILY_EXPORT_DIR=
# BROWSER_PROFILE_DIR=
# TEMPLATE_FOLDER=templates

# ── Scraping limits & timing ─────────────────────────────────────────────────
DAILY_LIMIT_DEFAULT=40
BUSINESS_QUERY_LIMIT=5000
YP_BASE_URL=https://www.yellowpages-uganda.com
YP_MAX_PAGES_PER_CATEGORY=60
YP_REQUEST_TIMEOUT=30
YP_REQUEST_DELAY=1.0
JIJI_MAX_PAGES_PER_CATEGORY=10
BROWSER_PAGE_LOAD_TIMEOUT=45
BROWSER_WINDOW_SIZE=1320,920

# ── Scheduler defaults ───────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=Africa/Kampala
SCHEDULE_HOUR_DEFAULT=8
SCHEDULE_MINUTE_DEFAULT=0
AUTOMATION_ENABLED_DEFAULT=1
DISABLED_PLATFORMS_DEFAULT=

# ── Email / SMTP (password-reset links) ──────────────────────────────────────
# Required only if you want the "Forgot password?" email flow to work.
# Gmail: create an App Password (Google Account > Security > 2-Step Verification
# > App passwords) and use it as SMTP_PASSWORD — NOT your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=you@gmail.com
# Set to 1 only if using implicit SSL on port 465; leave 0 for Gmail (STARTTLS).
SMTP_USE_SSL=0

# Base URL used to build links inside reset emails. Must be reachable by whoever
# clicks the link. Defaults to http://127.0.0.1:5050 (only works on this machine).
# APP_BASE_URL=http://127.0.0.1:5050

# How long a reset link stays valid (minutes).
RESET_TOKEN_TTL_MIN=60
